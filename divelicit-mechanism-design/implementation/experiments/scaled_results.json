      "max_error": 2.5673907444456745e-16,
      "n_perturbations": 108,
      "proof_sketch": "W(S) = -(1-\u03bb)\u00b7S_\u03b5(\u03bc_S, \u03bd) + \u03bb\u00b7\u03a3_{i\u2208S} q_i. Since S_\u03b5 depends only on embeddings {x_i}, not on {q_i}, W(S) = h_i(S, q_{-i}) + \u03bb\u00b7q_i\u00b7\ud835\udfd9[i\u2208S] where h_i(S, q_{-i}) = -(1-\u03bb)\u00b7S_\u03b5(\u03bc_S, \u03bd) + \u03bb\u00b7\u03a3_{j\u2208S,j\u2260i} q_j."
    },
    "part_b_exact_vcg_dsic": {
