{
  "apiVersion": "cascade-verify/v1",
  "kind": "ServiceMeshPolicy",
  "metadata": {
    "name": "production-mesh-policy",
    "namespace": "production",
    "labels": {
      "env": "production",
      "team": "platform-engineering"
    }
  },
  "spec": {
    "services": [
      {
        "name": "api-gateway",
        "capacity": 10000,
        "baselineLoad": 4000,
        "deadlineMs": 30000,
        "tier": 0,
        "port": 8080,
        "protocol": "HTTP"
      },
      {
        "name": "auth-service",
        "capacity": 5000,
        "baselineLoad": 2000,
        "tier": 1,
        "port": 8081,
        "protocol": "GRPC"
      },
      {
        "name": "user-service",
        "capacity": 3000,
        "baselineLoad": 1200,
        "tier": 1,
        "port": 8082,
        "protocol": "HTTP"
      },
      {
        "name": "notification-service",
        "capacity": 2000,
        "baselineLoad": 800,
        "tier": 2,
        "port": 8083,
        "protocol": "HTTP"
      },
      {
        "name": "email-gateway",
        "capacity": 500,
        "baselineLoad": 200,
        "tier": 3,
        "port": 8443,
        "protocol": "HTTPS"
      },
      {
        "name": "postgres-primary",
        "capacity": 2000,
        "baselineLoad": 900,
        "tier": 2,
        "port": 5432,
        "protocol": "TCP"
      },
      {
        "name": "redis-cluster",
        "capacity": 20000,
        "baselineLoad": 6000,
        "tier": 2,
        "port": 6379,
        "protocol": "TCP"
      }
    ],
    "dependencies": [
      {
        "source": "api-gateway",
        "target": "auth-service",
        "retryPolicy": {
          "maxRetries": 2,
          "perTryTimeoutMs": 1000,
          "retryOn": ["5xx", "connect-failure", "refused-stream"],
          "retryBudget": 0.2,
          "backoff": {
            "strategy": "exponential",
            "baseMs": 25,
            "maxMs": 250
          }
        },
        "timeoutPolicy": {
          "requestTimeoutMs": 5000,
          "perTryTimeoutMs": 1000,
          "idleTimeoutMs": 60000
        }
      },
      {
        "source": "api-gateway",
        "target": "user-service",
        "retryPolicy": {
          "maxRetries": 3,
          "perTryTimeoutMs": 3000,
          "retryOn": ["5xx", "reset", "connect-failure"],
          "backoff": {
            "strategy": "exponential",
            "baseMs": 50,
            "maxMs": 500
          }
        },
        "timeoutPolicy": {
          "requestTimeoutMs": 15000,
          "perTryTimeoutMs": 3000
        }
      },
      {
        "source": "api-gateway",
        "target": "notification-service",
        "retryPolicy": {
          "maxRetries": 1,
          "perTryTimeoutMs": 5000,
          "retryOn": ["5xx", "connect-failure"],
          "backoff": {
            "strategy": "fixed",
            "delayMs": 100
          }
        },
        "timeoutPolicy": {
          "requestTimeoutMs": 12000,
          "perTryTimeoutMs": 5000
        }
      },
      {
        "source": "user-service",
        "target": "postgres-primary",
        "retryPolicy": {
          "maxRetries": 2,
          "perTryTimeoutMs": 2000,
          "retryOn": ["connect-failure", "refused-stream"],
          "backoff": {
            "strategy": "exponential",
            "baseMs": 10,
            "maxMs": 200
          }
        },
        "timeoutPolicy": {
          "requestTimeoutMs": 8000,
          "perTryTimeoutMs": 2000
        },
        "circuitBreaker": {
          "consecutiveErrors": 5,
          "intervalMs": 10000,
          "baseEjectionTimeMs": 30000,
          "maxEjectionPercent": 50,
          "maxConnections": 200,
          "maxPendingRequests": 100
        }
      },
      {
        "source": "user-service",
        "target": "redis-cluster",
        "retryPolicy": {
          "maxRetries": 3,
          "perTryTimeoutMs": 500,
          "retryOn": ["connect-failure", "reset"],
          "backoff": {
            "strategy": "exponential",
            "baseMs": 10,
            "maxMs": 100
          }
        },
        "timeoutPolicy": {
          "requestTimeoutMs": 3000,
          "perTryTimeoutMs": 500
        }
      },
      {
        "source": "auth-service",
        "target": "redis-cluster",
        "retryPolicy": {
          "maxRetries": 2,
          "perTryTimeoutMs": 500,
          "retryOn": ["connect-failure", "reset"],
          "backoff": {
            "strategy": "exponential",
            "baseMs": 10,
            "maxMs": 100
          }
        },
        "timeoutPolicy": {
          "requestTimeoutMs": 2000,
          "perTryTimeoutMs": 500
        }
      },
      {
        "source": "notification-service",
        "target": "email-gateway",
        "retryPolicy": {
          "maxRetries": 4,
          "perTryTimeoutMs": 10000,
          "retryOn": ["5xx", "reset", "connect-failure", "gateway-error"],
          "retryBudget": 0.1,
          "backoff": {
            "strategy": "exponential",
            "baseMs": 500,
            "maxMs": 5000
          }
        },
        "timeoutPolicy": {
          "requestTimeoutMs": 55000,
          "perTryTimeoutMs": 10000,
          "upstreamDeadlineMs": 60000
        }
      },
      {
        "source": "notification-service",
        "target": "postgres-primary",
        "retryPolicy": {
          "maxRetries": 2,
          "perTryTimeoutMs": 2000,
          "retryOn": ["connect-failure"],
          "backoff": {
            "strategy": "exponential",
            "baseMs": 25,
            "maxMs": 250
          }
        },
        "timeoutPolicy": {
          "requestTimeoutMs": 8000,
          "perTryTimeoutMs": 2000
        }
      }
    ],
    "globalDefaults": {
      "retryPolicy": {
        "maxRetries": 2,
        "perTryTimeoutMs": 3000,
        "retryOn": ["5xx", "connect-failure"],
        "backoff": {
          "strategy": "exponential",
          "baseMs": 25,
          "maxMs": 1000
        }
      },
      "timeoutPolicy": {
        "requestTimeoutMs": 15000
      },
      "circuitBreaker": {
        "consecutiveErrors": 5,
        "intervalMs": 10000,
        "baseEjectionTimeMs": 30000,
        "maxEjectionPercent": 10
      },
      "rateLimiting": {
        "requestsPerSecond": 1000,
        "burstSize": 100
      }
    }
  }
}
