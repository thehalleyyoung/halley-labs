{
  "suite": "mutspec_core_v1",
  "description": "Core benchmark suite for MutSpec mutation-driven contract synthesis.",
  "version": "2.0.0",
  "programs": [
    {
      "name": "basic_arithmetic",
      "source": "examples/basic_arithmetic.ms",
      "functions": ["clamp"],
      "mutation_operators": ["ROR", "AOR"],
      "expected_mutants": 6,
      "ground_truth": {
        "clamp": {
          "preconditions": ["lo <= hi"],
          "postconditions": [
            "ret >= lo",
            "ret <= hi",
            "ret == x || ret == lo || ret == hi"
          ]
        }
      }
    },
    {
      "name": "array_bounds",
      "source": "examples/array_bounds.ms",
      "functions": ["safe_get", "safe_set"],
      "mutation_operators": ["ROR", "UOI", "AOR"],
      "expected_mutants": 7,
      "ground_truth": {
        "safe_get": {
          "preconditions": ["true"],
          "postconditions": [
            "(idx >= 0 && idx < 8) -> ret == arr[idx]",
            "(idx < 0 || idx >= 8) -> ret == default_val"
          ]
        }
      }
    },
    {
      "name": "absolute_value",
      "source": "examples/absolute_value.ms",
      "functions": ["abs"],
      "mutation_operators": ["ROR", "UOI"],
      "expected_mutants": 5,
      "ground_truth": {
        "abs": {
          "preconditions": ["true"],
          "postconditions": [
            "ret >= 0",
            "(x >= 0) -> ret == x",
            "(x < 0) -> ret == -x"
          ]
        }
      }
    },
    {
      "name": "max_function",
      "source": "examples/max_function.ms",
      "functions": ["max"],
      "mutation_operators": ["ROR"],
      "expected_mutants": 5,
      "ground_truth": {
        "max": {
          "preconditions": ["true"],
          "postconditions": [
            "ret >= a",
            "ret >= b",
            "ret == a || ret == b"
          ]
        }
      }
    },
    {
      "name": "linear_search",
      "source": "examples/linear_search.ms",
      "functions": ["linear_search"],
      "mutation_operators": ["ROR", "AOR", "UOI"],
      "expected_mutants": 7,
      "ground_truth": {
        "linear_search": {
          "preconditions": ["true"],
          "postconditions": [
            "ret >= -1",
            "ret <= 3",
            "(ret >= 0) -> arr[ret] == key",
            "(ret == -1) -> (arr[0] != key && arr[1] != key && arr[2] != key && arr[3] != key)"
          ]
        }
      }
    },
    {
      "name": "gap_analysis_demo",
      "source": "examples/gap_analysis_demo.ms",
      "functions": ["safe_divide"],
      "mutation_operators": ["ROR", "AOR", "UOI"],
      "expected_mutants": 8,
      "ground_truth": {
        "safe_divide": {
          "preconditions": ["divisor != 0"],
          "postconditions": [
            "(divisor > 0 && dividend >= 0) -> ret >= 0",
            "(divisor != 0) -> ret * divisor <= dividend",
            "(divisor != 0) -> dividend - ret * divisor >= 0",
            "(divisor != 0) -> dividend - ret * divisor < divisor"
          ]
        }
      }
    },
    {
      "name": "jml_output_demo",
      "source": "examples/jml_output_demo.ms",
      "functions": ["bounded_increment"],
      "mutation_operators": ["ROR", "AOR"],
      "expected_mutants": 6,
      "ground_truth": {
        "bounded_increment": {
          "preconditions": ["val >= lo", "val <= hi", "lo <= hi"],
          "postconditions": [
            "ret >= lo",
            "ret <= hi",
            "ret >= val",
            "ret <= val + 1"
          ]
        }
      }
    },
    {
      "name": "multi_function",
      "source": "examples/multi_function.ms",
      "functions": ["min", "max", "clamp_pair", "midpoint"],
      "mutation_operators": ["ROR", "AOR", "UOI"],
      "expected_mutants": 18,
      "ground_truth": {
        "min": {
          "preconditions": ["true"],
          "postconditions": ["ret <= a", "ret <= b", "ret == a || ret == b"]
        },
        "max": {
          "preconditions": ["true"],
          "postconditions": ["ret >= a", "ret >= b", "ret == a || ret == b"]
        },
        "clamp_pair": {
          "preconditions": ["lo <= hi"],
          "postconditions": ["ret >= lo", "ret <= hi"]
        },
        "midpoint": {
          "preconditions": ["true"],
          "postconditions": ["ret >= min(a, b)", "ret <= max(a, b)"]
        }
      }
    },
    {
      "name": "linked_list_length",
      "source": "examples/linked_list_length.ms",
      "functions": ["list_length"],
      "mutation_operators": ["ROR", "AOR", "UOI"],
      "expected_mutants": 8,
      "ground_truth": {
        "list_length": {
          "preconditions": ["true"],
          "postconditions": [
            "ret >= 0",
            "(head == null) -> ret == 0",
            "(head != null) -> ret >= 1"
          ]
        }
      }
    },
    {
      "name": "bst_lookup",
      "source": "examples/bst_lookup.ms",
      "functions": ["bst_contains", "bst_min"],
      "mutation_operators": ["ROR", "AOR", "LCR"],
      "expected_mutants": 10,
      "ground_truth": {
        "bst_contains": {
          "preconditions": ["true"],
          "postconditions": [
            "(root == null) -> ret == false",
            "(root.val == key) -> ret == true"
          ]
        },
        "bst_min": {
          "preconditions": ["root != null"],
          "postconditions": [
            "ret <= root.val"
          ]
        }
      }
    },
    {
      "name": "string_operations",
      "source": "examples/string_operations.ms",
      "functions": ["str_len", "char_at", "index_of"],
      "mutation_operators": ["ROR", "AOR", "UOI"],
      "expected_mutants": 12,
      "ground_truth": {
        "str_len": {
          "preconditions": ["s != null"],
          "postconditions": [
            "ret >= 0"
          ]
        },
        "char_at": {
          "preconditions": ["s != null", "idx >= 0", "idx < str_len(s)"],
          "postconditions": [
            "ret != '\\0'"
          ]
        },
        "index_of": {
          "preconditions": ["s != null"],
          "postconditions": [
            "ret >= -1",
            "ret < str_len(s)",
            "(ret >= 0) -> char_at(s, ret) == c"
          ]
        }
      }
    },
    {
      "name": "numeric_gcd",
      "source": "examples/numeric_gcd.ms",
      "functions": ["gcd", "is_prime"],
      "mutation_operators": ["ROR", "AOR", "UOI", "LCR"],
      "expected_mutants": 14,
      "ground_truth": {
        "gcd": {
          "preconditions": ["a > 0", "b > 0"],
          "postconditions": [
            "ret > 0",
            "ret <= a",
            "ret <= b",
            "a % ret == 0",
            "b % ret == 0"
          ]
        },
        "is_prime": {
          "preconditions": ["n >= 0"],
          "postconditions": [
            "(n < 2) -> ret == false",
            "(n == 2) -> ret == true"
          ]
        }
      }
    },
    {
      "name": "stack_operations",
      "source": "examples/stack_operations.ms",
      "functions": ["stack_push", "stack_pop", "stack_peek", "stack_is_empty"],
      "mutation_operators": ["ROR", "AOR", "UOI"],
      "expected_mutants": 11,
      "ground_truth": {
        "stack_push": {
          "preconditions": ["size < capacity"],
          "postconditions": [
            "new_size == old_size + 1",
            "stack[new_size - 1] == val"
          ]
        },
        "stack_pop": {
          "preconditions": ["size > 0"],
          "postconditions": [
            "new_size == old_size - 1",
            "ret == stack[old_size - 1]"
          ]
        },
        "stack_peek": {
          "preconditions": ["size > 0"],
          "postconditions": [
            "ret == stack[size - 1]",
            "new_size == old_size"
          ]
        },
        "stack_is_empty": {
          "preconditions": ["true"],
          "postconditions": [
            "(size == 0) -> ret == true",
            "(size > 0) -> ret == false"
          ]
        }
      }
    },
    {
      "name": "sorting_insertion",
      "source": "examples/sorting_insertion.ms",
      "functions": ["insertion_sort_step"],
      "mutation_operators": ["ROR", "AOR", "UOI"],
      "expected_mutants": 9,
      "ground_truth": {
        "insertion_sort_step": {
          "preconditions": ["n >= 0", "n < arr_len"],
          "postconditions": [
            "arr[n] <= arr[n] (original)",
            "forall i in [0..n]: arr[i] <= arr[i+1]"
          ]
        }
      }
    }
  ],
