{# Jinja2 template for CausalCert HTML audit report #}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CausalCert Audit Report</title>
    <style>
        :root {
            --primary: #0f3460;
            --primary-light: #16213e;
            --success: #28a745;
            --warning: #ffc107;
            --danger: #dc3545;
            --info: #17a2b8;
            --light: #f8f9fa;
            --dark: #1a1a2e;
        }
        * { box-sizing: border-box; }
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto,
                         'Helvetica Neue', Arial, sans-serif;
            max-width: 960px;
            margin: 0 auto;
            padding: 2em;
            color: var(--dark);
            line-height: 1.6;
            background: #fff;
        }
        h1 {
            color: var(--dark);
            border-bottom: 3px solid var(--primary);
            padding-bottom: 0.4em;
            margin-bottom: 1em;
        }
        h2 {
            color: var(--primary-light);
            border-bottom: 2px solid var(--primary);
            padding-bottom: 0.3em;
            margin-top: 2em;
        }
        h3 {
            color: var(--primary-light);
            margin-top: 1.5em;
        }
        p { margin: 0.6em 0; }
        strong { color: var(--primary-light); }

        /* Summary cards */
        .summary-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 1em;
            margin: 1em 0;
        }
        .card {
            background: var(--light);
            border: 1px solid #dee2e6;
            border-radius: 8px;
            padding: 1em;
            text-align: center;
        }
        .card-value {
            font-size: 2em;
            font-weight: bold;
            color: var(--primary);
        }
        .card-label {
            font-size: 0.85em;
            color: #666;
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }

        /* Tables */
        table {
            border-collapse: collapse;
            width: 100%;
            margin: 1em 0;
            font-size: 0.95em;
        }
        th, td {
            border: 1px solid #dee2e6;
            padding: 8px 12px;
            text-align: left;
        }
        th {
            background-color: var(--primary);
            color: white;
            font-weight: 600;
            position: sticky;
            top: 0;
        }
        tr:nth-child(even) { background-color: var(--light); }
        tr:hover { background-color: #e9ecef; }

        /* Sortable headers */
        th.sortable { cursor: pointer; }
        th.sortable:hover { background-color: #1a4a80; }

        /* Badges */
        .badge {
            display: inline-block;
            padding: 2px 10px;
            border-radius: 4px;
            font-size: 0.85em;
            font-weight: 600;
        }
        .badge-certified { background: var(--success); color: white; }
        .badge-gap { background: var(--warning); color: #333; }
        .badge-critical { background: var(--danger); color: white; }
        .badge-important { background: #fd7e14; color: white; }
        .badge-moderate { background: var(--warning); color: #333; }
        .badge-cosmetic { background: var(--success); color: white; }

        /* Score colouring */
        .fragile { color: var(--danger); font-weight: bold; }
        .robust { color: var(--success); font-weight: bold; }
        .moderate { color: #fd7e14; font-weight: bold; }

        /* Score bar */
        .score-bar {
            display: inline-block;
            height: 14px;
            border-radius: 3px;
            vertical-align: middle;
            margin-right: 6px;
        }

        /* Metadata */
        .meta {
            color: #666;
            font-size: 0.9em;
            margin-top: 2em;
            padding-top: 1em;
            border-top: 1px solid #dee2e6;
        }

        /* Responsive */
        @media (max-width: 600px) {
            body { padding: 1em; font-size: 0.9em; }
            table { font-size: 0.85em; }
            th, td { padding: 4px 6px; }
            .summary-grid { grid-template-columns: 1fr 1fr; }
        }

        /* Print */
        @media print {
            body { max-width: none; padding: 0; }
            th { background-color: #333 !important; -webkit-print-color-adjust: exact; }
        }
    </style>
</head>
<body>
    <h1>🔒 CausalCert Structural Robustness Audit</h1>

    {# ---- Summary ---- #}
    <h2>Summary</h2>
    <p>Treatment: <strong>{{ treatment_name }}</strong> → Outcome: <strong>{{ outcome_name }}</strong></p>
    <p>DAG: {{ n_nodes }} nodes, {{ n_edges }} edges</p>

    <div class="summary-grid">
        <div class="card">
            <div class="card-value">{{ radius.lower_bound }}</div>
            <div class="card-label">Robustness Radius (LB)</div>
        </div>
        <div class="card">
            <div class="card-value">{{ radius.upper_bound }}</div>
            <div class="card-label">Upper Bound</div>
        </div>
        <div class="card">
            <div class="card-value">
                {% if radius.certified %}
                    <span style="color: #28a745;">✓</span>
                {% else %}
                    <span style="color: #ffc107;">~</span>
                {% endif %}
            </div>
            <div class="card-label">
                {% if radius.certified %}Certified{% else %}Gap: {{ "%.1f"|format(radius.gap * 100) }}%{% endif %}
            </div>
        </div>
        <div class="card">
            <div class="card-value">{{ fragility_ranking|length }}</div>
            <div class="card-label">Edges Scored</div>
        </div>
    </div>

    {# ---- Robustness Radius ---- #}
    <h2>Robustness Radius</h2>
    <p>
        Lower bound: <strong>{{ radius.lower_bound }}</strong> |
        Upper bound: <strong>{{ radius.upper_bound }}</strong>
        {% if radius.certified %}
            <span class="badge badge-certified">CERTIFIED</span>
        {% else %}
            <span class="badge badge-gap">Gap: {{ "%.1f"|format(radius.gap * 100) }}%</span>
        {% endif %}
    </p>
    <p>Solver: {{ radius.solver_strategy.value }} | Time: {{ "%.2f"|format(radius.solver_time_s) }}s</p>

    {% if witness_edits %}
    <h3>Witness Edit Set</h3>
    <p>The following {{ witness_edits|length }} edit(s) overturn the conclusion:</p>
    <table>
        <thead>
            <tr><th>#</th><th>Edit Type</th><th>Source</th><th>Target</th></tr>
        </thead>
        <tbody>
            {% for edit in witness_edits %}
            <tr>
                <td>{{ loop.index }}</td>
                <td><span class="badge badge-critical">{{ edit.edit_type }}</span></td>
                <td>{{ edit.source }}</td>
                <td>{{ edit.target }}</td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
    {% endif %}

    {# ---- Fragility Ranking ---- #}
    {% if fragility_ranking %}
    <h2>Fragility Ranking</h2>
    <p>Top {{ fragility_ranking|length }} edges by composite fragility score:</p>
    <table>
        <thead>
            <tr>
                <th class="sortable">Rank</th>
                <th>Edge</th>
                <th class="sortable">Total</th>
                <th class="sortable">d-Sep</th>
                <th class="sortable">ID</th>
                <th class="sortable">Est</th>
            </tr>
        </thead>
        <tbody>
            {% for score in fragility_ranking %}
            <tr>
                <td>{{ loop.index }}</td>
                <td>{{ score.edge }}</td>
                <td>
                    {% set s = score.total_score %}
                    {% if s > 0.7 %}
                        <span class="fragile">{{ "%.3f"|format(s) }}</span>
                    {% elif s > 0.4 %}
                        <span class="moderate">{{ "%.3f"|format(s) }}</span>
                    {% elif s < 0.1 %}
                        <span class="robust">{{ "%.3f"|format(s) }}</span>
                    {% else %}
                        {{ "%.3f"|format(s) }}
                    {% endif %}
                </td>
                <td>{{ "%.3f"|format(score.channel_scores.get('d_separation', 0)) }}</td>
                <td>{{ "%.3f"|format(score.channel_scores.get('identification', 0)) }}</td>
                <td>{{ "%.3f"|format(score.channel_scores.get('estimation', 0)) }}</td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
    {% endif %}

    {# ---- Estimation ---- #}
    {% if baseline_estimate %}
    <h2>Estimation Results</h2>
    <h3>Baseline Estimate</h3>
    <table>
        <tr><th>ATE</th><th>SE</th><th>95% CI Lower</th><th>95% CI Upper</th><th>Method</th><th>N</th></tr>
        <tr>
            <td><strong>{{ "%.4f"|format(baseline_estimate.ate) }}</strong></td>
            <td>{{ "%.4f"|format(baseline_estimate.se) }}</td>
            <td>{{ "%.4f"|format(baseline_estimate.ci_lower) }}</td>
            <td>{{ "%.4f"|format(baseline_estimate.ci_upper) }}</td>
            <td>{{ baseline_estimate.method }}</td>
            <td>{{ baseline_estimate.n_obs }}</td>
        </tr>
    </table>

    {% if perturbed_estimates %}
    <h3>Perturbed Estimates</h3>
    <table>
        <tr><th>#</th><th>ATE</th><th>SE</th><th>CI Lower</th><th>CI Upper</th><th>Method</th></tr>
        {% for pe in perturbed_estimates %}
        <tr>
            <td>{{ loop.index }}</td>
            <td>{{ "%.4f"|format(pe.ate) }}</td>
            <td>{{ "%.4f"|format(pe.se) }}</td>
            <td>{{ "%.4f"|format(pe.ci_lower) }}</td>
            <td>{{ "%.4f"|format(pe.ci_upper) }}</td>
            <td>{{ pe.method }}</td>
        </tr>
        {% endfor %}
    </table>
    {% endif %}
    {% endif %}

    {# ---- Limitations ---- #}
    <h2>Limitations</h2>
    <ul>
        <li><strong>Faithfulness:</strong> Results assume the data-generating process is faithful to the DAG.</li>
        <li><strong>Identification:</strong> Only the back-door criterion is considered.</li>
        <li><strong>Statistical power:</strong> CI test power depends on sample size and conditioning set size.</li>
        {% if not radius.certified %}
        <li><strong>Optimality gap:</strong> The radius bound is not tight (gap: {{ "%.1f"|format(radius.gap * 100) }}%).</li>
        {% endif %}
    </ul>

    {# ---- Metadata ---- #}
    <h2>Metadata</h2>
    <p class="meta">
        Generated by CausalCert v{{ version }} |
        Seed: {{ seed }} |
        {{ timestamp }}
    </p>

    {# ---- Interactive sort script ---- #}
    <script>
    document.querySelectorAll('th.sortable').forEach(function(th) {
        th.addEventListener('click', function() {
            var table = th.closest('table');
            var tbody = table.querySelector('tbody');
            var rows = Array.from(tbody.querySelectorAll('tr'));
            var colIdx = Array.from(th.parentNode.children).indexOf(th);
            var asc = th.dataset.sort !== 'asc';
            th.dataset.sort = asc ? 'asc' : 'desc';
            rows.sort(function(a, b) {
                var va = parseFloat(a.children[colIdx].textContent) || 0;
                var vb = parseFloat(b.children[colIdx].textContent) || 0;
                return asc ? va - vb : vb - va;
            });
            rows.forEach(function(row) { tbody.appendChild(row); });
        });
    });
    </script>
</body>
</html>
