  {
    "case_study": "Seqlock Reader Pattern",
    "description": "Sequence lock reader: read sequence number, read data, read sequence number again. Writer increments sequence, writes data, increments sequence. Forbidden: reader sees matching (even) sequence numbers but inconsistent data.",
    "litmus_spec": {
      "name": "sequence_lock_reader",
      "n_threads": 2,
      "addresses": [
        "sequence",
        "data"
      ],
      "ops": [
        {
          "thread": 0,
          "optype": "load",
          "addr": "sequence",
          "reg": "r0"
        },
        {
          "thread": 0,
          "optype": "load",
          "addr": "data",
          "reg": "r1"
        },
        {
          "thread": 0,
          "optype": "load",
          "addr": "sequence",
          "reg": "r2"
        },
        {
          "thread": 1,
          "optype": "store",
          "addr": "sequence",
          "value": 1
        },
        {
          "thread": 1,
          "optype": "store",
          "addr": "data",
          "value": 42
        },
        {
          "thread": 1,
          "optype": "store",
          "addr": "sequence",
          "value": 2
        }
      ],
      "forbidden": {
        "r0": 2,
        "r1": 42,
        "r2": 2
      },
      "explanation": "The reader observes the sequence number unchanged before and after reading data, indicating no concurrent writer, but the data read is inconsistent with the sequence numbers, violating the lock's correctness."
    },
    "results": {
      "x86": {
        "safe": false,
        "fence": null
      },
      "sparc": {
        "safe": false,
        "fence": "membar #StoreStore|#LoadLoad"
      },
      "arm": {
        "safe": false,
        "fence": "dmb ishld (T0); dmb ishst (T1)"
      },
      "riscv": {
        "safe": false,
        "fence": "fence r,r (T0); fence w,w (T1)"
      },
      "opencl_wg": {
        "safe": false,
        "fence": "work_group_barrier(CLK_GLOBAL_MEM_FENCE)"
      },
      "opencl_dev": {
