        {
          "thread": 0,
          "optype": "store",
          "addr": "ptr",
          "value": 1
        },
        {
          "thread": 1,
          "optype": "load",
          "addr": "ptr",
          "reg": "r0"
        },
        {
          "thread": 1,
          "optype": "load",
          "addr": "data",
          "reg": "r1"
        }
      ],
      "forbidden": {
        "r0": 1,
        "r1": 0
      },
      "explanation": "Reader observes the new pointer but old data, violating message passing semantics in RCU."
