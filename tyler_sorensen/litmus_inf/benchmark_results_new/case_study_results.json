          "value": 42
        },
        {
          "thread": 0,
          "optype": "fence",
          "addr": "membar.cta"
        },
        {
          "thread": 0,
          "optype": "store",
          "addr": "done",
          "value": 1
        },
        {
          "thread": 1,
          "optype": "load",
          "addr": "done",
          "reg": "r0"
        },
        {
