[
  {
    "case_study": "SPSC Lock-Free Queue (enqueue/dequeue)",
    "description": "Single-producer single-consumer lock-free queue. Producer writes data to buffer[tail], then increments tail. Consumer reads tail, then reads buffer[old_tail]. The forbidden outcome is consumer seeing new tail but old data.",
    "litmus_spec": {
      "name": "sp_sc_lockfree_queue",
      "n_threads": 2,
      "addresses": [
        "buffer",
        "tail"
      ],
      "ops": [
        {
          "thread": 0,
          "optype": "store",
          "addr": "buffer",
          "value": 42
        },
        {
          "thread": 0,
          "optype": "store",
          "addr": "tail",
          "value": 1
        },
        {
          "thread": 1,
          "optype": "load",
          "addr": "tail",
          "reg": "r0"
        },
        {
          "thread": 1,
          "optype": "load",
          "addr": "buffer",
          "reg": "r1"
        }
      ],
      "forbidden": {
        "r0": 1,
        "r1": 0
      },
      "explanation": "Consumer sees updated tail indicating new data, but reads old buffer value, violating the expected ordering in a lock-free queue."
    },
    "results": {
      "x86": {
        "safe": true,
        "fence": null
      },
      "sparc": {
        "safe": false,
        "fence": "membar #StoreStore|#LoadLoad"
      },
      "arm": {
        "safe": false,
        "fence": "dmb ishst (T0); dmb ishld (T1)"
      },
      "riscv": {
        "safe": false,
        "fence": "fence w,w (T0); fence r,r (T1)"
      },
      "opencl_wg": {
        "safe": false,
        "fence": "work_group_barrier(CLK_GLOBAL_MEM_FENCE)"
      },
      "opencl_dev": {
        "safe": false,
        "fence": "atomic_work_item_fence(CLK_GLOBAL_MEM_FENCE, memory_order_acq_rel, memory_scope_device)"
      },
      "vulkan_wg": {
        "safe": false,
        "fence": "work_group_barrier(CLK_GLOBAL_MEM_FENCE)"
      },
      "vulkan_dev": {
        "safe": false,
        "fence": "atomic_work_item_fence(CLK_GLOBAL_MEM_FENCE, memory_order_acq_rel, memory_scope_device)"
      },
      "ptx_cta": {
        "safe": false,
        "fence": "membar.cta"
      },
      "ptx_gpu": {
        "safe": false,
        "fence": "membar.gl"
      }
    },
    "symmetry": {
      "automorphism_order": 1
    },
    "scope_mismatch": false
