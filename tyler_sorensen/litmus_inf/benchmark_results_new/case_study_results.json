  {
    "case_study": "Ticket Lock Acquire",
    "description": "Ticket lock: thread atomically increments 'next_ticket', then spins reading 'now_serving' until it matches. Another thread stores to 'now_serving' to release. Forbidden: acquiring thread sees its ticket number in now_serving but critical section data from previous holder.",
    "litmus_spec": {
      "name": "ticket_lock_forbidden",
      "n_threads": 2,
      "addresses": [
        "next_ticket",
        "now_serving",
        "critical_data"
      ],
      "ops": [
        {
          "thread": 0,
          "optype": "store",
          "addr": "next_ticket",
          "value": 1
        },
        {
          "thread": 0,
          "optype": "store",
          "addr": "critical_data",
          "value": 42
        },
        {
          "thread": 1,
          "optype": "load",
          "addr": "next_ticket",
          "reg": "r0"
        },
        {
          "thread": 1,
          "optype": "store",
          "addr": "next_ticket",
          "value": 2
        },
        {
          "thread": 1,
          "optype": "load",
          "addr": "now_serving",
          "reg": "r1"
        },
        {
          "thread": 1,
          "optype": "load",
          "addr": "critical_data",
          "reg": "r2"
        },
        {
          "thread": 1,
          "optype": "store",
          "addr": "now_serving",
          "value": 1
        }
      ],
      "forbidden": {
        "r1": 1,
        "r2": 42
      },
      "explanation": "The thread sees its ticket number in now_serving but the critical data reflects the previous holder, violating mutual exclusion."
    },
    "results": {
      "x86": {
        "safe": true,
        "fence": null
      },
