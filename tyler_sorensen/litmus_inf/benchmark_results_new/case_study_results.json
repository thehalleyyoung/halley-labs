  {
    "case_study": "GPU Reduction (Cross-Workgroup)",
    "description": "GPU parallel reduction across workgroups. Workgroup 0 writes partial sum to shared buffer, sets ready flag with workgroup barrier. Workgroup 1 reads ready flag with workgroup barrier, reads partial sum. Using workgroup-scope barriers for cross-workgroup communication.",
    "litmus_spec": {
      "name": "gpu_parallel_reduction_cross_workgroup",
      "n_threads": 2,
      "addresses": [
        "partial_sum",
        "ready_flag"
      ],
      "ops": [
        {
          "thread": 0,
          "optype": "store",
          "addr": "partial_sum",
          "value": 42
        },
        {
          "thread": 0,
          "optype": "store",
          "addr": "ready_flag",
          "value": 1
        },
        {
          "thread": 0,
          "optype": "fence",
          "addr": "shared"
        },
        {
          "thread": 1,
          "optype": "load",
          "addr": "ready_flag",
          "reg": "r0"
        },
        {
          "thread": 1,
          "optype": "fence",
          "addr": "shared"
        },
        {
          "thread": 1,
          "optype": "load",
          "addr": "partial_sum",
          "reg": "r1"
        }
      ],
      "forbidden": {
        "r0": 1,
        "r1": 0
      },
      "explanation": "Workgroup 1 reads ready_flag=1 but sees stale partial_sum=0, indicating a reordering or missing synchronization across workgroups."
    },
    "results": {
      "x86": {
        "safe": true,
        "fence": null
