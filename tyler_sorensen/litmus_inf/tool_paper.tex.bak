\end{tabular}
\end{table}

\subsection{Detailed DPOR Comparison}

\begin{table}[h]
\centering
\caption{Extended DPOR results with timing breakdown.}
\label{tab:dpor-detail}
\begin{tabular}{lrrrrrr}
\toprule
\textbf{Program} & \textbf{Threads} & \textbf{Ops/T} & \textbf{Vars} & \textbf{Full} & \textbf{POR} & \textbf{Reduction} \\
\midrule
2T-2ops-1var & 2 & 2 & 1 & 92    & 92    & 0.0\%  \\
2T-3ops-2var & 2 & 3 & 2 & 316   & 132   & 58.2\% \\
3T-2ops-1var & 3 & 2 & 1 & 8125  & 8125  & 0.0\%  \\
3T-2ops-2var & 3 & 2 & 2 & 2420  & 342   & 85.9\% \\
2T-4ops-2var & 2 & 4 & 2 & 1659  & 375   & 77.4\% \\
\bottomrule
\end{tabular}
\end{table}

\noindent\textbf{Observation:} POR provides no reduction when all accesses
target the same variable (all transitions are dependent).  Maximum reduction
occurs with multiple variables and multiple threads (3T-2ops-2var: 85.9\%),
confirming that POR is most effective when thread interactions are localized.

% ===========================================================================
% D. API REFERENCE
% ===========================================================================
\section{API Reference}
\label{app:api}

\subsection{Memory Model API}

\begin{lstlisting}[language=Python, caption={Memory model usage}]
from memory_model import (
    ExecutionBuilder, SequentialConsistency,
    TotalStoreOrder, get_model
)

# Build an execution
eb = ExecutionBuilder()
eb.init(0, 0)  # addr 0, initial value 0
eb.init(1, 0)
w0 = eb.write(0, 0, 1)  # thread 0 writes 1 to addr 0
r0 = eb.read(0, 1, 0)   # thread 0 reads 0 from addr 1
w1 = eb.write(1, 1, 1)
r1 = eb.read(1, 0, 0)
iw0 = eb.execution.init_writes[0]
iw1 = eb.execution.init_writes[1]
eb.rf(iw1, r0)  # reads-from relation
eb.rf(iw0, r1)
eb.co(iw0, w0)  # coherence order
eb.co(iw1, w1)
exe = eb.build()

# Check under different models
sc = SequentialConsistency()
result, reason = sc.check(exe)
# result: "allowed" or "forbidden"

# Factory function
model = get_model("TSO")
result, reason = model.check(exe)
\end{lstlisting}

\subsection{Litmus Test API}

\begin{lstlisting}[language=Python, caption={Litmus test framework}]
from litmus_test_engine import (
    make_store_buffering, generate_all_outcomes,
    check_outcome, classify_test,
    litmus_test_from_string, BUILTIN_TESTS
)

# Use built-in test
sb = make_store_buffering()
outcomes = generate_all_outcomes(sb)
classification = classify_test(sb)
# {'SC': 'forbidden', 'TSO': 'allowed', ...}

# Parse custom test
test = litmus_test_from_string("""
name: MyTest
init: x=0; y=0
T0: W(x)=1; r0=R(y)
T1: W(y)=1; r1=R(x)
forbidden: r0=0, r1=0
""")
\end{lstlisting}

\subsection{Race Detection API}

\begin{lstlisting}[language=Python, caption={Race detection}]
from race_detector import (
    HappensBeforeDetector, FastTrackDetector,
    make_trace_event
)

det = HappensBeforeDetector(n_threads=4)
det.process_event(make_trace_event(0, 'write', 'x', 1))
det.process_event(make_trace_event(1, 'read', 'x'))
races = det.get_races()
for race in races:
    print(f"Race on {race.address}")
\end{lstlisting}

\subsection{Fence Optimizer API}

\begin{lstlisting}[language=Python, caption={Fence optimization}]
from fence_optimizer import (
    FenceOptimizationPipeline, ConcurrentProgram
)

prog = ConcurrentProgram()
prog.add_store(0, 'x', 1)
prog.add_load(0, 'y')
prog.add_store(1, 'y', 1)
prog.add_load(1, 'x')

pipeline = FenceOptimizationPipeline()
result = pipeline.run(prog, target_model='arm')
print(f"Fences needed: {result['n_fences']}")
print(f"Verified: {result['verified']}")
\end{lstlisting}

\subsection{Model Checker API}

\begin{lstlisting}[language=Python, caption={Model checking}]
from model_checker import (
    ModelChecker, make_petersons_algorithm,
    mutual_exclusion_property
)

prog = make_petersons_algorithm()
mc = ModelChecker(prog)
result = mc.check(
    mutual_exclusion_property,
    method='bfs',
    depth_bound=50,
    use_por=True
)
print(f"Satisfied: {result.satisfied}")
print(f"States: {result.states_explored}")
\end{lstlisting}

\subsection{Deadlock Detector API}

\begin{lstlisting}[language=Python, caption={Deadlock detection}]
from deadlock_detector import DeadlockDetector

det = DeadlockDetector()
det.add_lock_event(0, 'A', 'acquire', timestamp=1)
det.add_lock_event(0, 'B', 'acquire', timestamp=2)
det.add_lock_event(0, 'B', 'release', timestamp=3)
det.add_lock_event(0, 'A', 'release', timestamp=4)
det.add_lock_event(1, 'B', 'acquire', timestamp=5)
det.add_lock_event(1, 'A', 'acquire', timestamp=6)
det.add_lock_event(1, 'A', 'release', timestamp=7)
det.add_lock_event(1, 'B', 'release', timestamp=8)

deadlocks = det.check()
# Reports AB-BA deadlock cycle
\end{lstlisting}

\subsection{Linearizability Checker API}

\begin{lstlisting}[language=Python, caption={Linearizability checking}]
from concurrent_data_structures import (
    LockFreeStack, LinearizabilityChecker, Operation
)

stack = LockFreeStack()
ops = []
stack.push(1, thread_id=0)
ops.append(Operation('push', 1, None, 0, 1, 0))
stack.push(2, thread_id=1)
ops.append(Operation('push', 2, None, 2, 3, 1))
v = stack.pop(thread_id=0)
ops.append(Operation('pop', None, v, 4, 5, 0))

checker = LinearizabilityChecker('stack')
is_lin, order = checker.check(ops)
\end{lstlisting}

% ===========================================================================
% E. FORMAL DEFINITIONS
% ===========================================================================
\section{Formal Definitions and Additional Proofs}
\label{app:formal}

\subsection{Axiomatic Memory Model Framework}

\begin{definition}[Execution]
An execution $E$ is a tuple $(W, R, F, \po, \rf, \co)$ where:
\begin{itemize}[nosep]
\item $W$ is the set of write events, each annotated with address and value.
\item $R$ is the set of read events, each annotated with address and value.
\item $F$ is the set of fence events, each annotated with fence type and scope.
\item $\po \subseteq (W \cup R \cup F)^2$ is the program order (per-thread
      total order).
\item $\rf \subseteq W \times R$ is the reads-from relation: $w \rf r$ means
      $r$ reads the value written by $w$.
\item $\co \subseteq W \times W$ is the coherence order: a per-address total
      order on writes to the same location.
\end{itemize}
\end{definition}

\begin{definition}[From-Reads]
The from-reads (or write serialization) relation is derived:
$r \xrightarrow{\text{fr}} w' \iff \exists w.\; w \rf r \land w \co w'$.
Intuitively, $r$ reads from a write that precedes $w'$ in coherence order,
so $r$ ``missed'' $w'$.
\end{definition}

\begin{definition}[Sequential Consistency]
An execution $E$ is SC-consistent iff the relation
$\po \cup \rf \cup \co \cup \text{fr}$ is acyclic.
\end{definition}

\begin{definition}[Total Store Order]
An execution $E$ is TSO-consistent iff the relation
$\text{ppo}_{\text{TSO}} \cup \rf_e \cup \co \cup \text{fr}$ is acyclic,
where $\text{ppo}_{\text{TSO}}$ is program order restricted to exclude
$W \po R$ pairs (store-load reordering is allowed), and $\rf_e$ is the
external reads-from (between different threads).
\end{definition}

\begin{definition}[Linearizability]
A concurrent history $H$ is linearizable with respect to a sequential
specification $S$ iff there exists a linearization---a total order $L$ on the
operations in $H$ such that:
\begin{enumerate}[nosep]
\item $L$ is consistent with the real-time order: if operation $o_1$ completes
      before $o_2$ begins, then $o_1 <_L o_2$.
\item The sequential history induced by $L$ is in the specification $S$.
\end{enumerate}
\end{definition}

\subsection{Correctness of Linearizability Checker}

\begin{theorem}[NP-Completeness of Linearizability]
Checking linearizability of a concurrent history is NP-complete in
general~\cite{Herlihy1990}.
\end{theorem}

Our implementation uses a backtracking search over possible linearizations,
pruning branches that violate the real-time ordering constraint.  For the
common case of stack and queue specifications, the search is efficient because
the specification constrains the linearization order significantly.

\begin{proposition}[Soundness of Linearizability Check]
If the \texttt{LinearizabilityChecker} returns \texttt{True} for a history $H$,
then $H$ is linearizable with respect to the specification.
\end{proposition}

\begin{proof}
The checker constructs an explicit linearization $L$ and verifies both
properties: (1) real-time ordering and (2) sequential specification
conformance.  The returned linearization serves as a constructive witness.
\end{proof}

\subsection{Correctness of Deadlock Detection}

\begin{definition}[Lock Order Graph]
Given a trace of lock events, the lock order graph $G = (V, E)$ has:
\begin{itemize}[nosep]
\item $V$ = set of all locks appearing in the trace.
\item $E$: directed edge $(A, B) \in E$ iff some thread acquires $B$ while
      holding $A$.
\end{itemize}
\end{definition}

\begin{theorem}[Deadlock Characterization]
A set of threads can deadlock iff the lock order graph contains a cycle.
\end{theorem}

\begin{proof}
(\emph{If}): Suppose the lock order graph has a cycle $A_1 \to A_2 \to \cdots
\to A_k \to A_1$.  For each edge $A_i \to A_{i+1}$, there exists a thread
$t_i$ that acquires $A_{i+1}$ while holding $A_i$.  If all threads execute
simultaneously and each $t_i$ acquires $A_i$ first, then $t_i$ waits for
$A_{i+1}$ (held by $t_{i+1}$), forming a circular wait---a deadlock by
Coffman's conditions.

(\emph{Only if}): If a deadlock exists, there is a circular wait chain
$t_1 \to t_2 \to \cdots \to t_k \to t_1$ where $t_i$ waits for a lock held
by $t_{i+1}$.  This induces a cycle in the lock order graph.
\end{proof}

\subsection{Partial Order Reduction Correctness}

\begin{definition}[Independence]
Two transitions $a$ and $b$ from state $s$ are \emph{independent} if:
\begin{enumerate}[nosep]
\item Both are enabled in $s$: $a \in \text{enabled}(s)$ and $b \in \text{enabled}(s)$.
\item Commutativity: executing $a$ then $b$ from $s$ reaches the same state
      as executing $b$ then $a$.
\item Enabledness: $a$ does not disable $b$ and vice versa.
\end{enumerate}
\end{definition}

\begin{definition}[Persistent Set]
A set $T \subseteq \text{enabled}(s)$ is \emph{persistent} in state $s$ if
for every finite execution sequence $t_1, t_2, \ldots, t_k$ from $s$ that
does not include any transition in $T$, every $t_i$ is independent with every
transition in $T$~\cite{Godefroid1997, Valmari1991}.
\end{definition}

\begin{theorem}[POR Preserves Deadlocks and Safety Properties]
\label{thm:por}
Exploring only persistent sets in each state preserves the reachability of
deadlock states and violations of state-based safety
properties~\cite{Peled1993}.
\end{theorem}

\begin{proof}[Proof Sketch]
Let $\sigma = t_1 t_2 \cdots t_n$ be an execution reaching a state $s'$ that
violates the property.  We show that the POR-reduced exploration also reaches
$s'$ (or a state equivalent to $s'$ up to the property).

At each state $s_i$ along $\sigma$, if the next transition $t_{i+1} \notin
T_{s_i}$ (the persistent set), then $t_{i+1}$ is independent with all
transitions in $T_{s_i}$.  By commutativity, we can reorder $\sigma$ to
execute a transition from $T_{s_i}$ first, eventually reaching the same
states.  By induction, the reduced exploration reaches $s'$.
\end{proof}

\subsection{Memory Model Monotonicity}

\begin{proposition}[Model Strength Ordering]
For the models implemented in \litmus{}, the following strength ordering holds
(where $M_1 \sqsubseteq M_2$ means every execution allowed by $M_1$ is also
allowed by $M_2$):
\[
\text{SC} \sqsubseteq \text{TSO} \sqsubseteq \text{PSO} \sqsubseteq \text{ARM/Relaxed}
\]
\end{proposition}

\begin{proof}
SC forbids all reorderings; TSO allows only store$\to$load; PSO additionally
allows store$\to$store; ARM allows all four reordering types.  Since each
successive model relaxes strictly more orderings, every SC-allowed execution
is TSO-allowed, every TSO-allowed execution is PSO-allowed, and every
PSO-allowed execution is ARM-allowed.
\end{proof}

This monotonicity property is confirmed by our experimental results in
Table~\ref{tab:mm-matrix}: the forbidden count decreases monotonically from
SC (6) through TSO/PSO/Relaxed (1 each).

