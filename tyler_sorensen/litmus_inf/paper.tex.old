\section{Portability Checking Algorithm}
\label{app:algorithm}

\begin{algorithm}[H]
\caption{Cross-Architecture Portability Check}
\label{alg:portcheck}
\begin{algorithmic}[1]
\REQUIRE Pattern $P$, target architecture $A$
\ENSURE Safe/Unsafe, fence recommendation
\STATE Enumerate all reads-from assignments $\mathit{RF}$
\STATE Enumerate all coherence orders $\mathit{CO}$
\FOR{each $(\mathit{rf}, \mathit{co}) \in \mathit{RF} \times \mathit{CO}$}
    \STATE Build global happens-before: $\mathit{ghb} = \mathit{ppo}(A) \cup \mathit{rf}_e \cup \mathit{co} \cup \mathit{fr}$
    \IF{$\mathit{ghb}$ is acyclic \AND outcome matches $F_P$}
        \RETURN Unsafe, compute\_min\_fences$(P, A)$
    \ENDIF
\ENDFOR
\RETURN Safe
\end{algorithmic}
\end{algorithm}

\begin{algorithm}[H]
\caption{Per-Thread Minimal Fence Computation}
\label{alg:fences}
\begin{algorithmic}[1]
\REQUIRE Pattern $P$, architecture $A$
\ENSURE Per-thread fence map
\FOR{each thread $t$ in $P$}
    \STATE $V_t \gets$ violated ordering pairs on thread $t$ under $A$
    \STATE $V_t \gets V_t \setminus$ \{pairs ordered by dependencies\}
    \STATE $V_t \gets V_t \setminus$ \{pairs ordered by existing fences\}
    \STATE fence$(t) \gets$ cheapest fence covering all pairs in $V_t$
\ENDFOR
\RETURN fence map
\end{algorithmic}
\end{algorithm}

\section{Performance Details}
\label{app:performance}

Full 570-pair analysis: mean 148.8\,ms, stdev 48.5\,ms (20 runs).
Individual 2-thread patterns: $<$1\,ms. Most expensive pattern
(2+2W, 3 threads): $\sim$6\,ms.

\section{Case Study Details}
\label{app:case-studies}

\subsection{SPSC Queue (x86 $\to$ ARM)}
Producer writes data then flag; consumer reads flag then data.
Maps to MP pattern. Fix: \texttt{dmb ishst} (T0); \texttt{dmb ishld}
(T1). Cost savings: 62.5\%.

\subsection{Dekker's Mutex (x86 $\to$ ARM)}
Each thread writes intent flag then reads other's flag.
Maps to SB pattern. Fix: \texttt{dmb ish} (both threads, full fence
required since both W$\to$R and R$\to$W orderings needed).

\subsection{CUDA Scope Mismatch}
CTA-scoped \texttt{\_\_threadfence\_block()} used for cross-CTA
communication. Fix: \texttt{\_\_threadfence()} (device scope) or
\texttt{membar.gl}.

\subsection{RISC-V Asymmetric Fence Pitfall}
\texttt{fence w,r} used where \texttt{fence w,w} is needed.
The sole ARM$\to$RISC-V discriminator in 57 patterns.

\section{LLM-Assisted Validation Details}
\label{app:llm}

5 scenarios analyzed with GPT-4.1-nano:
\begin{enumerate}[nosep]
\item Linux RCU grace period $\to$ MP pattern (correct)
\item Folly singleton double-checked lock $\to$ MP pattern (correct)
\item DPDK ring buffer enqueue/dequeue $\to$ SB pattern (correct)
\item Crossbeam epoch reclamation $\to$ IRIW pattern (correct)
\item CUDA parallel reduction $\to$ gpu\_mp\_wg (partial: correct pattern
      family but did not identify scope mismatch variant)
\end{enumerate}

