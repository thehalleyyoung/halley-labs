{
  "name": "mysql_phantom_gap_lock",
  "description": "MySQL InnoDB phantom anomaly under gap locking: the outcome depends on which index the optimizer selects for the predicate scan.",
  "engine": "mysql-8.0",
  "isolation_level": "repeatable_read",
  "schema": {
    "orders": {
      "columns": [
        { "name": "id", "type": "varchar", "nullable": false },
        { "name": "customer_id", "type": "integer", "nullable": false },
        { "name": "amount", "type": "integer", "nullable": false },
        { "name": "status", "type": "varchar", "nullable": false }
      ],
      "primary_key": "id",
      "indexes": [
        { "name": "idx_customer_id", "columns": ["customer_id"] },
        { "name": "idx_status", "columns": ["status"] }
      ]
    }
  },
  "initial_state": {
    "orders": [
      { "id": "order_100", "customer_id": 42, "amount": 100, "status": "pending" },
      { "id": "order_101", "customer_id": 42, "amount": 200, "status": "pending" },
      { "id": "order_102", "customer_id": 42, "amount": 150, "status": "pending" }
    ]
  },
  "transactions": [
    {
      "id": "T1",
      "operations": [
        { "type": "begin", "isolation": "repeatable_read" },
        { "type": "predicate_read", "table": "orders", "predicate": "customer_id = 42 AND status = 'pending'", "result_count": 3 },
        { "type": "write", "table": "orders", "key": "order_101", "column": "status", "value": "shipped" },
        { "type": "commit" }
      ]
    },
    {
      "id": "T2",
      "operations": [
        { "type": "begin", "isolation": "repeatable_read" },
        { "type": "insert", "table": "orders", "values": { "id": "order_200", "customer_id": 42, "amount": 50, "status": "pending" } },
        { "type": "commit" }
      ]
    }
  ],
  "expected_anomaly": "G2 (phantom) — index-dependent: safe with idx_customer_id, potentially unsafe with full table scan"
}
