{
  "name": "jepsen_history_analysis",
  "description": "Example of importing a Jepsen-style EDN history and analyzing it with IsoSpec. Demonstrates the Jepsen format integration for list-append workloads commonly used in distributed database testing.",
  "format": "jepsen_edn",
  "references": [
    "Kingsbury. Jepsen: Distributed Systems Safety Research. https://jepsen.io",
    "Kingsbury, Alvaro. Elle: Inferring Isolation Anomalies from Experimental Observations. VLDB 2020"
  ],
  "jepsen_history_edn": [
    "{:type :invoke, :f :txn, :value [[:r :x nil] [:w :y 1]], :process 0, :time 1000}",
    "{:type :ok, :f :txn, :value [[:r :x nil] [:w :y 1]], :process 0, :time 2000}",
    "{:type :invoke, :f :txn, :value [[:r :y nil] [:w :x 2]], :process 1, :time 1500}",
    "{:type :ok, :f :txn, :value [[:r :y nil] [:w :x 2]], :process 1, :time 2500}",
    "{:type :invoke, :f :txn, :value [[:r :x nil] [:r :y nil]], :process 2, :time 3000}",
    "{:type :ok, :f :txn, :value [[:r :x 2] [:r :y 1]], :process 2, :time 3500}",
    "{:type :invoke, :f :txn, :value [[:w :x 3] [:w :y 3]], :process 3, :time 3200}",
    "{:type :fail, :f :txn, :value [[:w :x 3] [:w :y 3]], :process 3, :time 3800}"
  ],
  "isospec_analysis": {
    "command": "isospec analyze --format jepsen-edn --isolation serializable history.edn",
    "expected_output": {
      "transactions": 4,
      "committed": 3,
      "aborted": 1,
      "anomalies_detected": [],
      "note": "T0 and T1 execute concurrently but write to different keys; T2 reads consistent values; T3 is aborted. No isolation anomaly under serializable."
    }
  },
  "usage_notes": {
    "supported_jepsen_models": [
      "list-append ([:r :key [values]] / [:append :key value])",
      "register ([:r value] / [:w value])",
      "bank ({:accounts {id balance ...}})",
      "key-value ([:r :key value] / [:w :key value] / [:cas :key old new])"
    ],
    "cli_usage": [
      "# Import Jepsen history",
      "isospec analyze --format jepsen-edn --isolation serializable tests/jepsen/history.edn",
      "",
      "# Export IsoSpec results to Jepsen EDN for integration",
      "isospec analyze --output-format edn workload.json > results.edn"
    ]
  }
}
