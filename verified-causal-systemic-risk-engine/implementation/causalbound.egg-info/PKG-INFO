## API Overview

### Network generation

```python
from causalbound.network.generators import ScaleFreeGenerator, ExposureParams

params = ExposureParams(distribution="pareto", scale=1e8, shape=1.5)
gen = ScaleFreeGenerator(exposure_params=params, seed=42)
G = gen.generate(n_nodes=100, m=3, alpha=1.0)
```

### DebtRank contagion

```python
from causalbound.contagion.debtrank import DebtRankModel, DebtRankVariant

model = DebtRankModel(variant=DebtRankVariant.LINEAR)
result = model.compute(G, initial_shocks={0: 1.0}, max_rounds=100)
print(f"System DebtRank: {result.system_debtrank:.4f}")

# Sensitivity analysis: which node matters most?
sensitivity = model.sensitivity_analysis(G, shock_level=1.0)
for node, impact in sensitivity.top_k_nodes[:5]:
    print(f"  Node {node}: impact = {impact:.4f}")
```

### Causal polytope LP

```python
from causalbound.polytope.causal_polytope import (
    CausalPolytopeSolver, DAGSpec, QuerySpec, SolverConfig
)

dag = DAGSpec(
    nodes=["X", "Y", "Z"],
    edges=[("X", "Y"), ("Y", "Z")],
    card={"X": 2, "Y": 2, "Z": 2},
)
query = QuerySpec(target_var="Z", target_val=1)
solver = CausalPolytopeSolver(config=SolverConfig(max_iterations=500))
result = solver.solve(dag, query)
print(f"Bounds: [{result.lower_bound:.6f}, {result.upper_bound:.6f}]")
```

### SMT verification

```python
from causalbound.smt.verifier import SMTVerifier, BoundEvidence

verifier = SMTVerifier(timeout_ms=10_000, emit_certificates=True)
session = verifier.begin_session()
vr = verifier.verify_bound(lower=0.1, upper=0.9, evidence=BoundEvidence(
    lp_objective=0.5,
    dual_values=[0.3, 0.7],
))
print(f"Verification: {vr.status.value}")
stats = verifier.end_session()
```

### MCTS adversarial search

```python
from causalbound.mcts.search import MCTSSearch, SearchConfig

config = SearchConfig(n_rollouts=5000, exploration_constant=1.414)
searcher = MCTSSearch(config=config, random_seed=42)
result = searcher.search(
    interface_vars=["X0", "X1", "X2"],
    inference_engine=engine,
    target_variable="X0",
)
print(f"Best scenario: {result.best_scenario.value:.4f}")
```

### Crisis reconstruction

```python
from causalbound.evaluation.crisis_reconstruction import CrisisReconstructor

reconstructor = CrisisReconstructor(seed=42)
crisis = reconstructor.reconstruct("gfc_2008")
print(f"GFC network: {crisis.graph.number_of_nodes()} nodes")
```

