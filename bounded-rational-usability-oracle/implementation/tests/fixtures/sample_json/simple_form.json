{
  "role": "document",
  "name": "Login Page",
  "children": [
    {
      "role": "form",
      "name": "Login",
      "children": [
        {
          "role": "textbox",
          "name": "Username",
          "description": "Enter your username",
          "properties": {"required": true},
          "boundingBox": {"x": 50, "y": 60, "width": 200, "height": 30}
        },
        {
          "role": "textbox",
          "name": "Password",
          "description": "Enter your password",
          "properties": {"required": true, "type": "password"},
          "boundingBox": {"x": 50, "y": 130, "width": 200, "height": 30}
        },
        {
          "role": "checkbox",
          "name": "Remember me",
          "properties": {"checked": false},
          "boundingBox": {"x": 50, "y": 180, "width": 20, "height": 20}
        },
        {
          "role": "button",
          "name": "Submit",
          "boundingBox": {"x": 50, "y": 220, "width": 100, "height": 40}
        }
      ],
      "boundingBox": {"x": 20, "y": 20, "width": 300, "height": 260}
    }
  ],
  "boundingBox": {"x": 0, "y": 0, "width": 1920, "height": 1080}
}
