  \node[state, below=1.0cm of s1] (s2) {$\sigma_2$: $(s,b,512)$};
  \node[state, below=1.0cm of s2] (s3) {$\sigma_3$: $(s,b,512)$};

  \draw[layer] (s0) -- node[right] {fc1} (s1);
